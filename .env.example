# Variaveis de ambiente da aplicacao 3 Sigilos.
# Copia este ficheiro para .env.local e preenche com as tuas chaves do Supabase.
# Nunca guardes estes valores no codigo nem os partilhes em maquinas alheias.

# URL do projeto Supabase (Project Settings, Data API, Project URL).
NEXT_PUBLIC_SUPABASE_URL=https://o-teu-projeto.supabase.co

# Chave publica anonima do Supabase (Project Settings, API Keys, anon public).
NEXT_PUBLIC_SUPABASE_ANON_KEY=a-tua-chave-anonima
