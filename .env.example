# Variaveis de ambiente da aplicacao dos N'ASA
# Copia este ficheiro para .env.local e preenche com as tuas chaves do Supabase.
# Nunca guardes estes valores no codigo nem os partilhes em maquinas alheias.

# URL do projeto Supabase (Project Settings, API, Project URL)
NEXT_PUBLIC_SUPABASE_URL=https://o-teu-projeto.supabase.co

# Chave publica anonima do Supabase (Project Settings, API, anon public)
NEXT_PUBLIC_SUPABASE_ANON_KEY=a-tua-chave-anonima

# URL base da aplicacao, usada nos links magicos de login.
# Em local: http://localhost:3000. No Vercel: o dominio de producao.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Envio automatico de propostas por email (opcional).
# Sem isto, a app continua a permitir o rascunho de email (mailto) e o PDF.
# Cria a chave em resend.com e verifica o teu dominio de envio.
RESEND_API_KEY=
RESEND_FROM=N'ASA <propostas@o-teu-dominio.pt>
